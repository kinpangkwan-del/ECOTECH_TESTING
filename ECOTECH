                            <option value="辦公室">辦公室除甲醛</option>
                            <option value="商鋪">商鋪除甲醛</option>
                            <option value="新車">新車除甲醛</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <textarea placeholder="您嘅查詢內容" required></textarea>
                    </div>
                    <button type="submit" class="submit-btn">提交查詢</button>
                </form>
            </div>
        </div>
    </section>

    <!-- 底部版權 -->
    <footer class="footer">
        <p>© 2024 清新環境除甲醛公司. 版權所有。</p>
    </footer>
</body>
</html>